{
  "name": "natalie-landing-page",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --watch",
    "dev": "npx serve . --listen 3000 --no-clipboard",
    "start": "npx serve . --listen 3000 --no-clipboard"
  },
  "devDependencies": {
    "@fontsource-variable/cormorant": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/pinyon-script": "^5.2.8",
    "@fontsource/sacramento": "^5.2.8",
    "tailwindcss": "^3.4.19"
  }
}
